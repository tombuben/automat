if GlobalManager.item_that_hit.item_name == "coffee_large"
	do GlobalManager.play_animation.emit("small_coffee_worker", "coffee")
	do GlobalManager.show_portrait("default")

	small_coffee_worker: Oh yeah I remember, they stopped making small cups.
	small_coffee_worker: Not because of ecology or anything.
	small_coffee_worker: Because people who drink small amounts of coffee won't achieve big things here.
	small_coffee_worker: Now, we just drink half of the medium cup.
	small_coffee_worker: Or I can share this large coffee with three people.
	small_coffee_worker: Yeah, imma do that
	=> small_worker_end


elif GlobalManager.item_that_hit.item_name == "coffee_medium"
	do GlobalManager.play_animation.emit("small_coffee_worker", "coffee")
	do GlobalManager.show_portrait("default")

	small_coffee_worker: Oh yeah I remember, they stopped making small cups.
	small_coffee_worker: Not because of ecology or anything.
	small_coffee_worker: Because people who drink small amounts of coffee won't achieve big things here.
	small_coffee_worker: Now, we just drink half of the medium cup.
	=> small_worker_end
	
elif GlobalManager.item_that_hit.item_name == "rubber_duck"
	do GlobalManager.play_animation.emit("small_coffee_worker", "hit")
	do GlobalManager.show_portrait("default")

	small_coffee_worker: Oh nice
	=> END!
	
elif GlobalManager.item_that_hit.item_name == "moral_compass"
	do GlobalManager.play_animation.emit("small_coffee_worker", "hit")
	do GlobalManager.show_portrait("default")

	small_coffee_worker: I dont know about that
	small_coffee_worker: I get your point though
	=> END!


else:
	=> small_worker_wrong_item

~ small_worker_wrong_item
