=> END!

# =========================
# Disposable worker 2
# =========================

~ disposable_worker_hit

# ===== PHASE CHECK =====
if GlobalManager.get_state("worker", "moral_unlocked", false):

	# =========================
	# Disposable worker 1
	# =========================
	
	
	if GlobalManager.item_that_hit.item_name == "moral_compass"
		do GlobalManager.show_portrait("default")
		do GlobalManager.play_animation.emit("disposable_worker", "throw")
		Disposable_worker: Did you just ARGUE with me?
		do GlobalManager.play_animation.emit("disposable_worker", "grin")

		Disposable_worker: I am filing a formal complaint
		Disposable_worker: Someone WILL read it in one to two calendar months
		do GlobalManager.play_animation.emit("disposable_worker", "idle")
		Disposable_worker: You should be REALLY afraid
		do GlobalManager.play_animation.emit("disposable_worker_leave")
		do wait(GlobalManager.current_animation_length)
		=> Small_coffee


	elif GlobalManager.item_that_hit.item_name == "coffee_large2"
		do GlobalManager.show_portrait("default")
		do GlobalManager.play_animation.emit("disposable_worker", "hit")
		Disposable_worker: Give me my swan art sprinkle latte
		Disposable_worker: I am not going away
		=> END!
	elif GlobalManager.item_that_hit.item_name == "coffee_medium"
		do GlobalManager.show_portrait("default")
		do GlobalManager.play_animation.emit("disposable_worker", "hit")
		Disposable_worker: You are RUINING my day
		=> END!
	elif GlobalManager.item_that_hit.item_name == "rubber_duck"
		do GlobalManager.show_portrait("default")
		do GlobalManager.play_animation.emit("disposable_worker", "hit")
		Disposable_worker: Why do you even have a duck?
		do GlobalManager.play_animation.emit("disposable_worker", "throw")
		Disposable_worker: I WANT MY COFFEE
		=> END!
		
	else:
		=> worker_wrong_item

else:

	# =========================
	# PHASE 1 (BEFORE UNLOCK)
	# =========================



	if GlobalManager.item_that_hit.item_name == "coffee_large"
		do GlobalManager.play_animation.emit("disposable_worker", "hit")
		do GlobalManager.show_portrait("default")
		do wait(1)
		Disposable_worker: This is just plain black coffee without any of the stuff I said
		Disposable_worker: We threw out one robot for [color=#ff851b][wave amp=25 freq=5]emotional malfunctions[/wave][/color] last week
		Disposable_worker: So you better behave

		Disposable_worker: Here is your basic bitter beverage back
		do GlobalManager.play_animation.emit("disposable_worker", "throw")
		do GlobalManager.play_animation.emit("coffeeCup")
		do wait(GlobalManager.current_animation_length)
		do GlobalManager.play_animation.emit("Screenshake")
		do GlobalManager.play_animation.emit("disposable_worker", "grin")
		
		do GlobalManager.show_portrait("automat")
		Automat: H-hey, wait this isnt fair!
		

		# 🔥 UNLOCK
		do GlobalManager.set_state("worker", "moral_unlocked", true)
		do GlobalManager.play_animation.emit("moral_compass_unlocked")
		do wait(3)
		do GlobalManager.play_animation.emit("Lock1")
		
		
		# SET SLOT DIALOGUES 2
		do GlobalManager.change_slot_item_name("ItemSlotCoffeeLarge", "coffee_large2")
		do GlobalManager.change_slot_item_saying("ItemSlotCoffeeLarge", "D-do you really not want this?")
		do GlobalManager.change_slot_item_saying("ItemSlotCoffeeMedium", "H-how about a medium?")
		do GlobalManager.change_slot_item_saying("ItemSlotRubberDuck", "D-duck?")
	
		do GlobalManager.change_slot_item_saying("GutsItemSlot", "But i dont even have any sprinkles, cream or swan art")
		=> END!
		
		
	elif GlobalManager.item_that_hit.item_name == "coffee_medium"
		do GlobalManager.show_portrait("default")
		do GlobalManager.play_animation.emit("disposable_worker", "hit")
		Disposable_worker: Not what I ordered
		Disposable_worker: Do it again, but THINK this time
		=> END!
	elif GlobalManager.item_that_hit.item_name == "rubber_duck"
		do GlobalManager.show_portrait("default")
		do GlobalManager.play_animation.emit("disposable_worker", "hit")
		Disposable_worker: But I didnt want a duck?!
		Disposable_worker: I just want my coffee
		=> END!
	else:
		=> worker_wrong_item



