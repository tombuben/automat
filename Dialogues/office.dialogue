		=> END!
	elif GlobalManager.item_that_hit.item_name == "mind2"
		do GlobalManager.play_animation.emit("dramatic_worker", "hit")
		Printer: Yeah... It could be dangerous
		=> END!
	elif GlobalManager.item_that_hit.item_name == "moral_compass2"
		do GlobalManager.play_animation.emit("dramatic_worker", "hit")
		Printer: ...
		=> END!
	else:
		do GlobalManager.play_animation.emit("printer", "hit")
		dramatic_worker: ...
		=> END!


else:

	# =========================
	# PHASE 1 (DEFAULT)
	# =========================

	if GlobalManager.item_that_hit.item_name == "coffee_large"
	
		do GlobalManager.show_portrait("printer")
		do GlobalManager.play_animation.emit("printer", "hit")

		Printer: Okay you got me, I can't actually drink coffee
		Printer: That's not why I am here

