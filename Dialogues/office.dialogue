do GlobalManager.change_slot_item_saying("ItemSlotCoffeeLarge", "[color=#1bffc2]H-here you go[/color]")
	
do GlobalManager.change_slot_item_name("ItemSlotCoffeeMedium", "coffee_medium")
do GlobalManager.change_slot_item_saying("ItemSlotCoffeeMedium", "[color=#1bffc2]H-here you go[/color]")
	
do GlobalManager.change_slot_item_name("ItemSlotRubberDuck", "rubber_duck")
do GlobalManager.change_slot_item_saying("ItemSlotRubberDuck", "[color=#1bffc2]D-duck?[/color]")

do GlobalManager.change_slot_item_name("GutsItemSlot", "moral_compass")
do GlobalManager.change_slot_item_saying("GutsItemSlot", "[color=#1bffc2]Um... I...[/color]")

do GlobalManager.change_slot_item_name("MindItemSlot", "mind")
do GlobalManager.change_slot_item_saying("MindItemSlot", "[color=#1bffc2]I-I only wanted to help[/color]")

do GlobalManager.change_slot_item_name("HeartItemSlot", "heart")
do GlobalManager.change_slot_item_saying("HeartItemSlot", "[color=#1bffc2]S-sorry I...[/color]")

=> END!

# =========================
# MAIN INTERACTION
# =========================

~ boss_hit


if GlobalManager.item_that_hit.item_name == "coffee_large"
	do GlobalManager.play_animation.emit("boss", "coffee")
	do GlobalManager.show_portrait("boss")
	boss: ...
	do GlobalManager.show_portrait("automatSad")
	automat: [color=#1bffc2]...[/color]
	do GlobalManager.show_portrait("boss")
	boss: You are done
	=> Chapter0End

elif GlobalManager.item_that_hit.item_name == "coffee_medium"
	do GlobalManager.play_animation.emit("boss", "hit")
	boss: Cant you follow a simple request?
	boss: I will cut this from your pay
	=> END!
elif GlobalManager.item_that_hit.item_name == "rubber_duck"
	do GlobalManager.play_animation.emit("boss", "hit")
	boss: No.
	=> END!
elif GlobalManager.item_that_hit.item_name == "mind"
	do GlobalManager.play_animation.emit("boss", "hit")
	boss: Maybe you should just do your job
	boss: Instead of "helping"
	=> END!
elif GlobalManager.item_that_hit.item_name == "moral_compass"
	do GlobalManager.play_animation.emit("boss", "hit")
	boss: Why are you even talking
	boss: We got a machine to be the exact opposite of that

	=> END!
elif GlobalManager.item_that_hit.item_name == "heart"
	do GlobalManager.play_animation.emit("boss", "hit")
	boss: Stop talking
	boss: You are not here for "expression"
	boss: Give me the coffee
	=> END!

~ Chapter0End
do wait(2)
do GlobalManager.play_animation.emit("Cinematic0")
do wait(10)
do GlobalManager.load_into_scene(1)