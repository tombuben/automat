~ duckman_hit

if GlobalManager.item_that_hit.item_name == "bread"
	duckman: thanks for the bread!
	do GlobalManager.play_animation.emit("duckman_leave")
	do wait(GlobalManager.current_animation_length)
	=> drowning_person_enter
elif "metal" in GlobalManager.item_that_hit.item_type:
	duckman: OUCH you hit me with a metal thing!
	#do GlobalManager.person_shoot_selection_started.emit()
	=> END!
else
	duckman: what is this! give me something else!
	#do GlobalManager.person_shoot_selection_started.emit()
	=> END!



~ capitalist_payment
do GlobalManager.play_animation.emit("capitalist_payment_enter")
do wait(GlobalManager.current_animation_length)
=> END!





