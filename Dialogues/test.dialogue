~ duckman
do GlobalManager.play_animation.emit("duckman_enter")
do wait(GlobalManager.current_animation_length)
do GlobalManager.play_animation.emit("duckman_idle")

duckman: Hi! Im duckman and i want bread!
do wait(GlobalManager.current_animation_length)

=> END!
#do GlobalManager.recieve_item.emit("egg")
