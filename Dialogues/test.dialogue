~ day1_start
=> capitalist_first_enter

~ capitalist_first_enter
#do GlobalManager.play_animation.emit("screen_expand")

do GlobalManager.play_animation.emit("capitalist_enter")
do wait(GlobalManager.current_animation_length)

do GlobalManager.play_animation.emit("capitalist_idle")

capitalist: You are either making money or going to the trash
capitalist: Okay, now try giving me the licence
do wait(GlobalManager.current_animation_length)

=> END!

~ capitalist_hit
if GlobalManager.item_that_hit.hit_speed > 50:
	capitalist: fast hit!
if GlobalManager.item_that_hit.item_name == "licence"
	capitalist: EEP

elif "bread" in GlobalManager.item_that_hit.item_type:
	capitalist: That's bread. You just gave me bread.
	capitalist: It's pretty stale now
	=> END!

elif "donut" in GlobalManager.item_that_hit.item_type:
	capitalist: Please for the love of god just give me the licence
	=> END!

elif "fishFood" in GlobalManager.item_that_hit.item_type:
	capitalist: It tastes like salty sand
	capitalist: GIVE ME THE LICENCE
	=> END!

elif "hammer" in GlobalManager.item_that_hit.item_type:
	capitalist: I cannot die
	capitalist: I still need to be rich
	=> END!

elif "frog" in GlobalManager.item_that_hit.item_type:
	capitalist: All my businesses have failed
	capitalist: I think you are about to be the fifth one
	=> END!

else
	capitalist: what is this! give me something else!
	#do GlobalManager.person_shoot_selection_started.emit()
	=> END!
	

capitalist: Okay, now try to make money somehow this way.

 - How do I make money? =>< know_me_disagree
	do wait(0)
	~ know_me_disagree
	do wait(0)
	capitalist: Real funny
	=> capitalist_end_convo

 - But what even is money? =>< know_me_agree
	do wait(0)
	~ know_me_agree
	capitalist: I care way too little about you to explain
	capitalist: Please try to exist usefully
	=> capitalist_end_convo


~ capitalist_end_convo
capitalist: I am off to pouring water out of my sunken house
capitalist: I will be back

do GlobalManager.play_animation.emit("capitalist_leave")
do wait(GlobalManager.current_animation_length)
=> duckman

#do GlobalManager.play_animation.emit("screen_expand")
#do wait(GlobalManager.current_animation_length)

#do GlobalManager.play_animation.emit("screen_shrink")

~ duckman
do GlobalManager.play_animation.emit("duckman_enter")
do wait(GlobalManager.current_animation_length)
do GlobalManager.play_animation.emit("duckman_idle")

duckman: Hi! Im duckman and i want bread!
do wait(GlobalManager.current_animation_length)

=> END!
#do GlobalManager.recieve_item.emit("egg")
#do GlobalManager.person_shoot_selection_started.emit()

~ duckman_hit

if GlobalManager.item_that_hit.item_name == "bread"
	duckman: thanks for the bread!
	do GlobalManager.play_animation.emit("duckman_leave")
	do wait(GlobalManager.current_animation_length)
	=> drowning_person_enter
elif "metal" in GlobalManager.item_that_hit.item_type:
	duckman: OUCH you hit me with a metal thing!
	#do GlobalManager.person_shoot_selection_started.emit()
	=> END!
else
	duckman: what is this! give me something else!
	#do GlobalManager.person_shoot_selection_started.emit()
	=> END!

~ drowning_person_enter
	
do GlobalManager.play_animation.emit("drowning_person_enter")
do wait(GlobalManager.current_animation_length)
do GlobalManager.play_animation.emit("drowning_person_idle")
Hello, very sorry to bother you
I just wanted to ask if you could help.
I am drowning.

I was too shy to ask, but my feet are way too tired now
I-I have money of course, could you help please?
=> END!

~ drowning_person_hit
if GlobalManager.item_that_hit.item_name == "safety_donut"
	drowing person: O-Oh thank you, sorry to bother you again!
	do GlobalManager.play_animation.emit("drowning_person_leave")
	do wait(GlobalManager.current_animation_length)
	=> capitalist_payment
=> END!

~ capitalist_payment
do GlobalManager.play_animation.emit("capitalist_payment_enter")
do wait(GlobalManager.current_animation_length)
=> END!





